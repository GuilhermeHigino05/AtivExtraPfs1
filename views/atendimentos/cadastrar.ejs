
<h1>Cadastrar Atendimento</h1>

<div class="container">
    <form>
        <div class="mb-3">
            <h3>Informações do veículo</h3>
            <div>
                <div class="alert alert-danger" role="alert" id="erros" style="display:none">

                </div>
                <div class="alert alert-success" role="alert" id="alertaSucesso" style="display:none;" >
                    
                </div>
                <form>
                    <div class="form-row">
                        <div class="form-group col-md-4">
                            <label for="inputPlaca">Placa:</label>
                            <input maxlength="7" type="text" class="form-control" id="inputPlaca">
                            <button type="button" id="btnBuscarVeiculo" class="btn btn-secondary mt-2">Buscar Veículo</button>
                        </div>
                    </div>
                    <div class="form-row">
                    <div class="form-group col-md-6">
                        <label for="inputModelo">Modelo:</label>
                        <input type="text" class="form-control" id="inputModelo">
                    </div>
                    <div class="form-group col-md-6">
                        <label for="inputMarca">Marca:</label>
                        <input type="text" class="form-control" id="inputMarca">
                    </div>
                    </div>
                    <div class="form-group">
                        <div class="form-row">
                            <div class="form-group col-md-6">
                                <label for="inputAno">Ano:</label>
                                <input type="text" class="form-control" id="inputAno">
                            </div>
                            <div class="form-group col-md-6">
                                <label for="inputKilometragem">Kilometragem:</label>
                                <input type="number" class="form-control" id="inputKilometragem">
                            </div>
                        </div>  
                    </div>
                    <br><br>
                    
                </form>
            </div>

            <select multiple class="form-control" id="selectServicos">
                <% if (typeof servico !== 'undefined' && servico.length > 0) { %>
                    <% for(let i = 0; i < servico.length; i++) { %>
                        <option value="<%= servico[i].servId %>" data-valor="<%= servico[i].servValor %>"><%= servico[i].servDesc %> - R$ <%= servico[i].servValor %></option>
                    <% } %>
                <% } %>
            </select>

        </div>
        <button type="button" id="btnCadastrar" class="btn btn-primary">Cadastrar Atendimento</button>
    </form>
</div>

<script src="/js/atendimentos/cadastro.js"></script>